Escribir "Ingrese porcentaje de avance real:"
Leer avance
Escribir "Ingrese número de errores detectados:"
Leer errores
Escribir "¿Presentó documentación completa? (S/N):"
Leer docCompleta
Escribir "¿Realizó exposición final? (S/N):"
Leer exposicion
// Validación de notas
Si analisis < 0 O analisis > 10 O diseno < 0 O diseno > 10 O codificacion < 0
Ocodificacion > 10 Entonces
Escribir "Error: Las notas deben estar entre 0 y 10"
SiNo
// Cálculo del promedio técnico
promedio <- (analisis + diseno + codificacion) / 3
// Ajustes por errores
ajustes <- ajustes - (errores * 0.5)
// Ajustes por documentación
Si docCompleta = "S" Entonces
ajustes <- ajustes + 0.5
FinSi
// Ajustes por exposición
Si exposicion = "S" Entonces
ajustes <- ajustes + 0.5
FinSi
// Nota final
notaFinal <- promedio + ajustes
// Límites de la nota
Si notaFinal > 10 Entonces
notaFinal <- 10
FinSi
